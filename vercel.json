{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/app/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/backend/app/main" },
    { "src": "/upload", "dest": "/backend/app/main" },
    { "src": "/convert", "dest": "/backend/app/main" },
    { "src": "/(.*)", "dest": "frontend/dist/$1" }
  ]
}
